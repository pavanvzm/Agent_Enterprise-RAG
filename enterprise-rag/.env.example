# ---- Auth ----
# local = built-in demo issuer (HS256). auth0 = verify against your Auth0 tenant (RS256/JWKS).
RAG_AUTH_MODE=local
RAG_JWT_SECRET=change-me-to-a-long-random-string
RAG_TOKEN_TTL_MINUTES=60

# Auth0 (only when RAG_AUTH_MODE=auth0)
RAG_AUTH0_DOMAIN=your-tenant.us.auth0.com
RAG_AUTH0_AUDIENCE=https://enterprise-rag-api
RAG_AUTH0_ROLES_CLAIM=https://enterprise-rag/roles

# ---- Models ----
# Leave empty to run fully offline (hashed embeddings + extractive answers).
RAG_OPENAI_API_KEY=
RAG_OPENAI_BASE_URL=https://api.openai.com/v1
RAG_EMBEDDING_PROVIDER=auto        # auto | openai | sentence-transformers | hashed
RAG_EMBEDDING_MODEL=text-embedding-3-small
RAG_LLM_PROVIDER=auto              # auto | openai | fallback
RAG_LLM_MODEL=gpt-4o-mini

# ---- Storage ----
RAG_CHROMA_PATH=./data/chroma
RAG_AUDIT_DB_PATH=./data/audit.db

# ---- RAG tuning ----
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=120
RAG_TOP_K=5
